# ==========================================
# 🎓 COLLEGE MANAGEMENT SYSTEM CONFIGURATIONS
# ==========================================

# 1. Server Port
# The port number on which the backend server listens (e.g. 5000)
PORT=5000

# 2. Node Environment
# Set to 'development' for local coding, or 'production' for live hosting
NODE_ENV=development

# 3. JWT Signing Secret
# A highly secure random secret string used to sign user tokens.
# IMPORTANT: Change this to a long, complex key in production!
JWT_SECRET=your_super_secure_random_jwt_secret_key_change_me

# 4. Database File Location (SQLite)
# The relative or absolute path to the SQLite DB storage file
DATABASE_URL=src/database/college.db
